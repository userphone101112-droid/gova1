{
  "name": "gova",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "npm run ci:check && npm run registry:generate && npm run maol:diff && next build --webpack",
    "start": "next start --port 3001",
    "server": "tsx scripts/dev-server.ts",
    "server:start": "tsx scripts/dev-server.ts start",
    "server:stop": "tsx scripts/dev-server.ts stop",
    "server:restart": "tsx scripts/dev-server.ts restart",
    "server:status": "tsx scripts/dev-server.ts status",
    "server:logs": "tsx scripts/dev-server.ts logs",
    "server:clear-cache": "tsx scripts/dev-server.ts clear-cache",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:eslint-ui": "node src/platform/ui/enforcement/eslint/require-data-ui-uuid.test.js && node src/platform/ui/enforcement/eslint/ui-uuid-ban.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:export": "tsx scripts/export-to-json.ts",
    "db:check": "tsx scripts/check-db.ts",
    "db:validate-images": "tsx scripts/validate-images.ts",
    "db:analyze": "tsx scripts/analyze-db.ts",
    "i18n:validate": "tsx src/platform/ui/enforcement/scripts/validate-translations.ts",
    "i18n:validate-bindings": "tsx src/platform/ui/enforcement/scripts/validate-registry-bindings.ts",
    "i18n:sync": "tsx src/platform/ui/enforcement/scripts/sync-translations.ts",
    "i18n:generate-keys": "tsx src/platform/ui/enforcement/scripts/generate-translation-keys.ts",
    "i18n": "npm run ci:i18n",
    "generate:feature": "tsx scripts/generate-feature.ts",
    "audit:unified-ui-i18n": "tsx src/platform/ui/enforcement/scripts/audit-unified-ui-i18n.ts",
    "audit:orphans": "tsx src/platform/ui/enforcement/scripts/find-orphans.ts",
    "registry:materialize-uuids": "tsx scripts/registry-materialize-uuids.ts",
    "registry:add": "tsx scripts/registry-add-identity.ts",
    "registry:move": "tsx scripts/registry-move-identity.ts",
    "registry:remove": "tsx scripts/registry-remove-identity.ts",
    "registry:validate-uuids": "tsx scripts/registry-validate-uuids.ts",
    "i18n:prune-orphans": "tsx src/platform/ui/enforcement/scripts/prune-orphans.ts",
    "registry:generate": "tsx scripts/registry-generate.ts",
    "ci:uuid-dom-absolute": "tsx scripts/ci-uuid-dom-absolute.ts",
    "ci:uuid-dom-parity": "tsx scripts/ci-uuid-dom-parity.ts",
    "ci:registry-integrity": "tsx scripts/ci-registry-integrity.ts",
    "ci:project-legacy-scan": "tsx scripts/ci-project-legacy-scan.ts",
    "ci:ui-legacy-guard": "tsx scripts/ci-ui-legacy-guard.ts",
    "platform:doctor": "tsx scripts/platform-doctor.ts",
    "ci:i18n": "npm run registry:validate-uuids && npm run i18n:sync && npm run i18n:validate && npm run i18n:validate-bindings && npm run i18n:generate-keys",
    "ci:check": "npm run registry:validate-uuids && npm run ci:registry-integrity && npm run typecheck && npm run lint && npm run test:eslint-ui && npm run ci:uuid-dom-absolute && npm run ci:uuid-dom-parity && npm run ci:i18n && npm run audit:unified-ui-i18n && npm run maol:diff && npm run validate:theme && npm run ci:ui-legacy-guard && npm run ci:project-legacy-scan",
    "ci:enforcement": "npm run typecheck && npm run lint && npm run ci:i18n && npm run validate:theme && npm run audit:unified-ui-i18n && npm run audit:orphans",
    "ci:pre-commit": "npm run ci:i18n",
    "prebuild": "npm run ci:i18n && npm run registry:generate && npm run validate:theme",
    "maol:diff": "tsx src/platform/ui/enforcement/scripts/track-ui-identity-diff.ts",
    "maol:test": "tsx scripts/test-maol.ts",
    "audit:design-system": "tsx scripts/audit-design-system.ts",
    "validate:theme": "tsx scripts/validate-theme-compliance.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "better-sqlite3": "^12.10.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.14.0",
    "lucide-react": "^1.18.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
