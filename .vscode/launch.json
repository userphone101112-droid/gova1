{
    // Gova Project - VSCode Launch Configurations
    // Server managed via: scripts/dev-server.ts
    // All server commands use npm run server:<action>
    "version": "0.2.0",
    "configurations": [

        // ── Development Server ───────────────────────────────────────────
        {
            "type": "node",
            "request": "launch",
            "name": "▶ Dev: Start (Next.js inline)",
            "preLaunchTask": "Server: Stop + Kill Port 3001",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "cwd": "${workspaceFolder}",
            "env": {
                "NODE_ENV": "development",
                "PORT": "3001"
            },
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "▶ Server: Start (detached + health check)",
            "preLaunchTask": "Server: Stop + Kill Port 3001",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "server:start"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "⏹ Server: Stop",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "server:stop"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🔄 Server: Restart",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "server:restart"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "📊 Server: Status",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "server:status"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "📋 Server: View Logs",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "server:logs"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🗑 Server: Clear Cache",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "server:clear-cache"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },

        // ── Debugger Attachment ──────────────────────────────────────────
        {
            "type": "node",
            "request": "attach",
            "name": "🐛 Attach Debugger to Running Server",
            "port": 9229,
            "skipFiles": ["<node_internals>/**"],
            "restart": true
        },

        // ── Database Tools ───────────────────────────────────────────────
        {
            "type": "node",
            "request": "launch",
            "name": "🗄 DB: Export SQLite → JSON",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "db:export"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🗄 DB: Check Database",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "db:check"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🗄 DB: Analyze Database",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "db:analyze"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },

        // ── Code Quality ─────────────────────────────────────────────────
        {
            "type": "node",
            "request": "launch",
            "name": "✅ TypeScript: Type Check",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "typecheck"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🧪 Tests: Run All",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "test"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🧪 Tests: Watch Mode",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "test:watch"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}